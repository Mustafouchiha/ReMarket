{
  "version": 2,
  "buildCommand": "npm install && cd ikki_frontend && npm install && npm run build",
  "outputDirectory": "ikki_frontend/dist",
  "framework": null,
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
